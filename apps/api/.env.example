# Research Directory API — environment

# Postgres connection (Supabase: Project Settings → Database → Connection string).
# The API is the only thing that connects to Postgres.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# Server
PORT=4000
# Comma-separated allowed CORS origins (the Vite dev server, the deployed SPA).
WEB_ORIGIN=http://localhost:5173

# No auth in V1 — the directory is public and read-only.
